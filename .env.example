# Copiar este archivo a .env.local y completar con los valores reales.
# No subir .env.local al repositorio (añadir .env.local a .gitignore).

# Base de datos MySQL (proyecto Grupo Emprenor)
# En entornos locales, el host puede ser 'localhost' o 'source' según el servidor.
DB_HOST=localhost
DB_USER=tu_usuario_bd
DB_PASSWORD=tu_password_bd
DB_NAME=tu_nombre_bd

# Obligatorio para login y dashboards (firmar sesiones JWT)
JWT_SECRET=generar_una_clave_larga_y_aleatoria
