# Copiar este archivo a .env.local y completar con los valores reales.
# No subir .env.local al repositorio (añadir .env.local a .gitignore).

# Base de datos Neon (PostgreSQL) - URL de conexión pooled (recomendada para Vercel)
# Obtenerla en: https://console.neon.tech → tu proyecto → Connection string (pooled)
DATABASE_URL=postgresql://usuario:password@host/neondb?sslmode=require

# Alternativa: Vercel/Neon suelen ofrecer también
# POSTGRES_URL=postgresql://...

# Obligatorio para login y dashboards (firmar sesiones JWT)
JWT_SECRET=generar_una_clave_larga_y_aleatoria
